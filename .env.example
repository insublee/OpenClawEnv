# ── 필수 ──
# Google Gemini API 키 (https://aistudio.google.com/apikey 에서 발급)
GEMINI_API_KEY=

# 텔레그램 봇 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# ── 메모리 연동 ──
MEMORY_REPO_URL=https://github.com/insublee/Insub-Bot-Memory

# ── 선택 ──
# Notion API 키
NOTION_API_KEY=

# Google OAuth (캘린더/드라이브 등)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub 토큰 (프라이빗 레포 접근 등)
GITHUB_TOKEN=